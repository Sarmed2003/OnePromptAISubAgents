# Application
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# API Configuration
API_TIMEOUT=30000
API_RATE_LIMIT=100

# Database (if applicable)
# DATABASE_URL=postgresql://user:password@localhost:5432/app_db

# Authentication
# AUTH_SECRET=your-secret-key-here
# JWT_EXPIRY=24h

# Monitoring
# SENTRY_DSN=https://key@sentry.io/project-id
# ENABLE_METRICS=true
