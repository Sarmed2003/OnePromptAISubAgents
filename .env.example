# Environment
NODE_ENV=development
PORT=3000

# Application
APP_NAME=api-platform
APP_VERSION=1.0.0

# Logging
LOG_LEVEL=info

# API Configuration
API_TIMEOUT=30000
API_MAX_REQUEST_SIZE=10mb

# CORS
CORS_ORIGIN=http://localhost:3000

# Security
AUTH_ENABLED=false
AUTH_SECRET=your-secret-key-here

# Database/Storage (if needed)
STORAGE_TYPE=memory

# Monitoring
METRICS_ENABLED=false
TRACING_ENABLED=false
