# Environment Configuration
# Copy this file to .env and update values for your environment

# Server Configuration
# PORT: The port on which the server listens for incoming requests
# Default: 3000
PORT=3000

# Node Environment
# NODE_ENV: Sets the application runtime environment
# Allowed values: development, production
# development: Enables verbose logging and hot-reload features
# production: Optimized for performance and security
NODE_ENV=development

# Authentication
# API_KEY: Optional API key for request authentication
# If set, API requests must include this key in the Authorization header
# Leave commented out if authentication is not required
# Example: API_KEY=your-api-key-here
# API_KEY=

# Logging
# LOG_LEVEL: Controls the verbosity of application logs
# Allowed values: debug, info, warn, error
LOG_LEVEL=info

# Database/Storage (if applicable)
# DATABASE_URL: Connection string for your database
# Example: DATABASE_URL=postgresql://user:password@localhost:5432/mydb
# DATABASE_URL=

# NOTES_TABLE: DynamoDB table name for storing notes (if using DynamoDB)
# Example: NOTES_TABLE=notes-dev
# NOTES_TABLE=notes-dev
