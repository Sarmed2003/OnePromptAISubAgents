# ==============================================================================
# OnePromptAI Configuration
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env — it is gitignored.

# --- Gemini LLM Configuration ---
# [REQUIRED] Your Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Model to use (gemini-2.0-flash is free-tier friendly)
GEMINI_MODEL=gemini-2.0-flash

# Temperature for LLM sampling (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.7

# Max output tokens per request
LLM_MAX_TOKENS=8192

# --- Git Configuration ---
# [REQUIRED] URL of the target repository workers will clone and commit to
GIT_REPO_URL=https://github.com/your-username/your-target-repo.git

# [REQUIRED] GitHub Personal Access Token with push access
GIT_TOKEN=ghp_your-github-token-here

# Primary branch name
GIT_MAIN_BRANCH=main

# Prefix for worker branches
GIT_BRANCH_PREFIX=worker/

# Git identity for commits
GIT_COMMIT_NAME=OnePromptAI Bot
GIT_COMMIT_EMAIL=agent@onepromptai.bot

# --- Worker Configuration ---
# Max parallel workers (keep low for MacBook Air, 3-5 recommended)
MAX_WORKERS=3

# Timeout per worker task in seconds
WORKER_TIMEOUT=600

# Merge strategy: fast-forward | rebase | merge-commit
MERGE_STRATEGY=merge-commit

# --- Database Backend ---
# Options: dynamodb | mongodb | memory
# DynamoDB is recommended when using AWS (no setup needed, serverless)
DB_BACKEND=dynamodb

# --- AWS Configuration ---
# Region for DynamoDB and other AWS services
AWS_REGION=us-east-1

# AWS credentials — set via environment, ~/.aws/credentials, or IAM role
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Table name prefix for DynamoDB tables
DYNAMODB_TABLE_PREFIX=onepromptai

# --- MongoDB Configuration (only if DB_BACKEND=mongodb) ---
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB=onepromptai

# --- Orchestrator ---
# Path to the local clone of the target repository
TARGET_REPO_PATH=./target-repo

# Reconciler health check interval in seconds
HEALTH_CHECK_INTERVAL=30

# Finalization settings
FINALIZATION_ENABLED=true
FINALIZATION_MAX_ATTEMPTS=3

# --- Logging ---
LOG_LEVEL=info
