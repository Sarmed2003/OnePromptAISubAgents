# ==============================================================================
# OnePromptAI Configuration
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env — it is gitignored.

# --- LLM Provider ---
# Options: bedrock | gemini | ollama
# bedrock = AWS (uses AWS_ACCESS_KEY_ID etc.; consumes credits, no Gemini quotas)
# gemini  = Google AI Studio API key
# ollama  = local models
LLM_PROVIDER=bedrock

# --- AWS Bedrock
# Docs: https://docs.aws.amazon.com/bedrock/latest/userguide/conversation-inference.html
# Model access (legacy “Model access” page retired): serverless models are enabled by
# default with correct IAM + AWS Marketplace permissions. First invoke can start a
# background subscription (wait up to ~15 min). Anthropic: one-time “First Time Use”
# form in Bedrock console → Model catalog (or API PutUseCaseForModelAccess).
# https://docs.aws.amazon.com/bedrock/latest/userguide/model-access.html
#
# IAM: bedrock:InvokeModel (and bedrock:InvokeModelWithResponseStream if used).
# First-time Marketplace models: aws-marketplace:Subscribe, ViewSubscriptions.
#
# Model IDs: https://docs.aws.amazon.com/bedrock/latest/userguide/model-ids.html
# Default: Claude 3.5 Haiku via US cross-region inference profile (required when
# on-demand base model ID is not supported). List profiles without the AWS CLI:
#   python -m oneprompt.bedrock_tools
# (same credentials as the app). Optional CLI: aws bedrock list-inference-profiles --region us-east-1
# Recommended: Claude Haiku 4.5 (fast, cheap, great for worker agents)
# Premium alternative: us.anthropic.claude-sonnet-4-6 (higher quality, slower, costlier)
# First-party (no Anthropic FTU): amazon.nova-lite-v1:0
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_REGION=us-east-1
# Cap for Converse maxTokens (must be <= model output limit; lower if ValidationException)
BEDROCK_MAX_OUTPUT_TOKENS=8192

# --- Gemini (optional, if LLM_PROVIDER=gemini) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Temperature for LLM sampling (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.7

# Max output tokens per request
LLM_MAX_TOKENS=8192

# --- Ollama (local fallback / primary) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
FALLBACK_TO_OLLAMA=true

# --- Git Configuration ---
# [REQUIRED] URL of the target repository workers will clone and commit to
GIT_REPO_URL=https://github.com/your-username/your-target-repo.git

# [REQUIRED] GitHub Personal Access Token with push access
GIT_TOKEN=ghp_your-github-token-here

# Primary branch name
GIT_MAIN_BRANCH=main

# Prefix for worker branches
GIT_BRANCH_PREFIX=worker/

# Git identity for commits
GIT_COMMIT_NAME=OnePromptAI Bot
GIT_COMMIT_EMAIL=agent@onepromptai.bot

# --- Worker Configuration ---
# Max parallel workers (keep low for MacBook Air, 3-5 recommended)
MAX_WORKERS=3

# Timeout per worker task in seconds
WORKER_TIMEOUT=600

# Merge strategy: fast-forward | rebase | merge-commit
MERGE_STRATEGY=merge-commit

# --- Database Backend ---
# Options: dynamodb | mongodb | memory
# DynamoDB is recommended when using AWS (no setup needed, serverless)
DB_BACKEND=dynamodb

# --- AWS Configuration ---
# Region for DynamoDB and other AWS services
AWS_REGION=us-east-1

# AWS credentials — set via environment, ~/.aws/credentials, or IAM role
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Table name prefix for DynamoDB tables
DYNAMODB_TABLE_PREFIX=onepromptai

# --- MongoDB Configuration (only if DB_BACKEND=mongodb) ---
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB=onepromptai

# --- Orchestrator ---
# Path to the local clone of the target repository
TARGET_REPO_PATH=./target-repo

# Cap file paths sent to planner/subplanner (monorepos = huge trees = long hangs). 0 = no cap.
MAX_FILE_TREE_LINES=600

# Parallel subplanner LLM calls before workers start
SUBPLANNER_MAX_PARALLEL=4

# Reconciler health check interval in seconds
HEALTH_CHECK_INTERVAL=30

# Finalization settings
FINALIZATION_ENABLED=true
FINALIZATION_MAX_ATTEMPTS=3

# --- Logging ---
LOG_LEVEL=info

# --- Knowledge vault (Obsidian-friendly markdown on disk) ---
# Point VAULT_PATH at the folder you open in Obsidian (or a subfolder for agent notes).
# .obsidian/ and runs/ are never sent to the LLM. Frontmatter --- blocks are stripped.
# Subfolders loaded first for the planner: memory/, decisions/, patterns/, architecture/, errors/
# VAULT_ENABLED=true
# VAULT_PATH=./vault
# VAULT_MAX_CONTEXT_CHARS=6000

# --- SDLC phases (affect which “roles” appear on the dashboard) ---
# STRICT_SDLC=true runs all enabled phases in order; SMART_PHASE_SELECTION is off when strict.
# With STRICT_SDLC=false and SMART_PHASE_SELECTION=true, some phases may be skipped — fewer role rows.
# ARCHITECT_ENABLED=true
# REVIEW_ENABLED=true
# QA_ENABLED=true
# SECURITY_ENABLED=true
# DEVOPS_ENABLED=true
# STRICT_SDLC=true
# SMART_PHASE_SELECTION=false

# --- Optional prompt template pack (folder under templates/<name>/) ---
# TEMPLATE=
