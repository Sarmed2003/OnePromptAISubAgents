# Production: https://xxxx.execute-api.region.amazonaws.com/prod
VITE_API_URL=

# Optional: S3/CloudFront base for future GLTF or texture packs
VITE_ASSET_BASE=

# On *.vercel.app builds only: set "true" to show the full Bedrock form (needs working VITE_API_URL + CORS).
# Leave unset or "false" to keep the public “coming soon” + mascot experience on Vercel.
# VITE_ALLOW_VERCEL_RESEARCH=true

# Optional: on non-Vercel hosts, set "true" to force the same “coming soon” UI as Vercel.
# VITE_RESEARCH_COMING_SOON=true
