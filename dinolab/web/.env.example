# Dinolab Web Application Environment Variables
# This file documents all VITE_* environment variables required by the web app.
# Copy this file to .env.local and fill in values for your deployment environment.
# WARNING: Never commit actual secrets or API keys to version control.

# ============================================================================
# API Configuration
# ============================================================================

# VITE_API_URL
# Purpose: Base URL for the backend API server that handles research data,
#          bedrock form submissions, and other API requests.
# Usage: Used throughout the app to construct API endpoints (e.g., /api/submit).
# Default: (empty - must be set for API calls to work)
# Production: Set to your production API Gateway URL
#             Example: https://xxxx.execute-api.us-east-1.amazonaws.com/prod
# Development: http://localhost:3001 (or your local API server)
# Security: Must use HTTPS in production. Ensure CORS is properly configured
#           on the backend to prevent unauthorized cross-origin requests.
# Note: If left empty, API-dependent features will fail gracefully.
VITE_API_URL=

# ============================================================================
# Asset & CDN Configuration
# ============================================================================

# VITE_ASSET_BASE
# Purpose: Base URL for static assets such as GLTF 3D models, textures, and
#          other binary asset packs. Allows serving assets from S3, CloudFront,
#          or other CDN instead of the application server.
# Usage: Prepended to asset paths when loading 3D models and texture files.
# Default: (empty - assets served from app root)
# Production: Set to CloudFront distribution URL or S3 bucket URL
#             Example: https://d123456.cloudfront.net/assets
#             or: https://my-bucket.s3.amazonaws.com/assets
# Development: Leave empty to serve assets from public/ directory
# Security: Use signed URLs or CloudFront policies to restrict access to assets
#           if they contain proprietary or sensitive data.
# Note: Ensure trailing slashes are consistent across asset paths.
VITE_ASSET_BASE=

# ============================================================================
# Feature Flags & UI Behavior
# ============================================================================

# VITE_ALLOW_VERCEL_RESEARCH
# Purpose: Controls whether to show the full Bedrock research form on Vercel
#          preview deployments. When false/unset, shows a "coming soon" UI
#          with mascot instead of the interactive form.
# Usage: Checked on app startup to determine which UI to render.
# Default: false (or unset)
# Production: Set to "true" only if:
#             - Deployed to *.vercel.app domain
#             - VITE_API_URL is set and points to a working API
#             - Backend CORS is configured to accept requests from Vercel domain
#             - You want to enable research submissions on preview builds
# Development: Leave unset or "false" to use coming soon UI for testing.
# Values: "true" or "false" (or unset for false)
# Security: Setting this to "true" exposes the research form. Ensure your API
#           has proper authentication, rate limiting, and input validation.
# Note: This variable is Vercel-specific; use VITE_RESEARCH_COMING_SOON for
#       non-Vercel environments to achieve similar behavior.
# VITE_ALLOW_VERCEL_RESEARCH=false

# VITE_RESEARCH_COMING_SOON
# Purpose: Forces the "coming soon" UI (with mascot) on non-Vercel hosts.
#          Useful for staging or development environments where you want to
#          hide the research form temporarily.
# Usage: Checked on app startup; overrides normal form display logic.
# Default: false (or unset)
# Production: Set to "true" if you want to hide the research form on
#             production or staging deployments while keeping the app live.
# Development: Leave unset or "false" to show the form for testing.
# Values: "true" or "false" (or unset for false)
# Note: This is independent of VITE_ALLOW_VERCEL_RESEARCH. Both can be used
#       in different environments to control UI visibility.
# VITE_RESEARCH_COMING_SOON=false

# ============================================================================
# Environment-Specific Recommendations
# ============================================================================
#
# Local Development:
#   VITE_API_URL=http://localhost:3001
#   VITE_ASSET_BASE=
#   VITE_ALLOW_VERCEL_RESEARCH=false
#   VITE_RESEARCH_COMING_SOON=false
#
# Vercel Preview (with API):
#   VITE_API_URL=https://api-staging.example.com
#   VITE_ASSET_BASE=https://cdn-staging.example.com/assets
#   VITE_ALLOW_VERCEL_RESEARCH=true
#   VITE_RESEARCH_COMING_SOON=false
#
# Vercel Preview (without API):
#   VITE_API_URL=
#   VITE_ASSET_BASE=
#   VITE_ALLOW_VERCEL_RESEARCH=false
#   VITE_RESEARCH_COMING_SOON=true
#
# Production:
#   VITE_API_URL=https://api.example.com
#   VITE_ASSET_BASE=https://cdn.example.com/assets
#   VITE_ALLOW_VERCEL_RESEARCH=false (unless deployed to Vercel)
#   VITE_RESEARCH_COMING_SOON=false
