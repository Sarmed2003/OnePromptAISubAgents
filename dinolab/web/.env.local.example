# Local Development Environment Configuration
# Copy this file to .env.local and customize for your local setup
# This file is safe to commit and serves as a template for developers

# ============================================================================
# Application Environment
# ============================================================================
# Controls which environment configuration is loaded (development, test, production)
# For local development, use 'development' to enable hot reloading and verbose logging
NODE_ENV=development

# ============================================================================
# Frontend Server Configuration
# ============================================================================
# The port on which the local dev server runs
# Change this if port 3000 is already in use on your machine
PORT=3000

# The hostname the dev server binds to
# 'localhost' restricts to local machine only; use '0.0.0.0' to allow network access
HOST=localhost

# ============================================================================
# API Endpoints
# ============================================================================
# Base URL for API requests from the frontend
# Points to local backend server for development
# Override for testing: set to http://localhost:4000 if backend runs on different port
# For integration testing against staging: REACT_APP_API_URL=https://api-staging.example.com
REACT_APP_API_URL=http://localhost:3001

# WebSocket endpoint for real-time features (if applicable)
# Local development uses same host as API endpoint
# Override for testing: WS_URL=ws://localhost:4000 or wss://staging.example.com
REACT_APP_WS_URL=ws://localhost:3001

# ============================================================================
# Authentication & Tokens
# ============================================================================
# Mock/test authentication token for local development
# This is a dummy token used for testing without a real auth service
# In production, this comes from actual login flow
# Override for testing: set to real token from staging auth service
REACT_APP_AUTH_TOKEN=local-dev-token-12345

# Authentication service URL (if using separate auth service)
# Points to local auth mock server
# Override for testing: REACT_APP_AUTH_URL=https://auth-staging.example.com
REACT_APP_AUTH_URL=http://localhost:3002

# ============================================================================
# Feature Flags
# ============================================================================
# Enable verbose console logging during development
# Set to 'false' to reduce console noise
REACT_APP_DEBUG=true

# Enable experimental features in local development
# Set to 'false' to test production behavior
REACT_APP_EXPERIMENTAL_FEATURES=true

# Enable mock API responses for offline/isolated testing
# Set to 'true' to bypass real API calls and use mock data
# Useful for UI development without backend dependency
REACT_APP_USE_MOCK_API=false

# ============================================================================
# Analytics & Monitoring
# ============================================================================
# Analytics tracking ID (disabled for local development)
# Leave empty or commented out in development to avoid polluting analytics
# Override for testing: REACT_APP_ANALYTICS_ID=UA-XXXXXXXXX-X
REACT_APP_ANALYTICS_ID=

# Enable error reporting to Sentry (disabled for local development)
# Set to empty string to disable error tracking locally
# Override for testing: REACT_APP_SENTRY_DSN=https://key@sentry.io/project
REACT_APP_SENTRY_DSN=

# ============================================================================
# Third-Party Services
# ============================================================================
# Google Maps API Key (if application uses maps)
# Use a local/test key or leave empty for development
# Override for testing: use staging key from secure vault
REACT_APP_GOOGLE_MAPS_KEY=

# Stripe Public Key (if application handles payments)
# Use test/publishable key for local development
# Override for testing: use staging publishable key
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_local_development

# ============================================================================
# File Upload & Storage
# ============================================================================
# Local file upload endpoint
# Points to local backend file service or mock endpoint
# Override for testing: REACT_APP_UPLOAD_URL=https://upload-staging.example.com
REACT_APP_UPLOAD_URL=http://localhost:3001/upload

# Maximum file upload size in bytes (10MB for local development)
# Increase or decrease based on local testing needs
REACT_APP_MAX_UPLOAD_SIZE=10485760

# ============================================================================
# Development Tools & Utilities
# ============================================================================
# Enable Redux DevTools browser extension integration
# Useful for debugging state management
REACT_APP_REDUX_DEVTOOLS=true

# Enable performance profiling in development
# Set to 'false' if profiling overhead impacts development
REACT_APP_ENABLE_PROFILING=true

# ============================================================================
# Localization & Internationalization
# ============================================================================
# Default language for local development
# Change to test different language implementations
REACT_APP_DEFAULT_LANGUAGE=en

# Enable translation debugging (shows translation keys instead of values)
# Useful for identifying missing translations
REACT_APP_DEBUG_TRANSLATIONS=false

# ============================================================================
# Testing & QA
# ============================================================================
# Test mode flag for running application in test configuration
# Set to 'true' when running automated tests
# Override: TEST_MODE=true npm test
REACT_APP_TEST_MODE=false

# Seed data for local development database
# Set to 'true' to auto-populate with sample data on startup
REACT_APP_SEED_DATA=true

# ============================================================================
# Quick Reference for Common Overrides
# ============================================================================
# To test against different backend:
#   REACT_APP_API_URL=http://localhost:4000 npm start
#
# To test with mock API only:
#   REACT_APP_USE_MOCK_API=true npm start
#
# To test production behavior:
#   NODE_ENV=production npm start
#
# To run tests with specific configuration:
#   REACT_APP_TEST_MODE=true npm test
#
# To access from other machines on network:
#   HOST=0.0.0.0 npm start
